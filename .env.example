# Postgres (used by postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshortener

# App (url-shortener service)
IMAGE_NAME=ghcr.io/<username>/<repo-name>:latest
CONTAINER_NAME=url-shortener
PORT=3000

# Redis (url-shortener service)
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=86400

# Rate Limiting (url-shortener service)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Node Identification (url-shortener service)
SERVER_ID=url-shortener
